FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //



// ************************************************************************* //
solvers
{
 
  rhoUE
    {
		solver    		GMRES;
		preconditioner  ILUC0;
		tolerance       1e-05;
		relTol          0.01;
		minIter         1;
		maxIter			1000;
		nDirections		5;
    }
    
    rhoS
    {
		solver    		GMRES;
		preconditioner  ILUC0;
		tolerance       1e-05;
		relTol          0.01;
		minIter         1;
		maxIter			1000;
		nDirections		5;
    }

    rho
    {
        solver          GMRES;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0;
    }

    rhoU
    {
		type			coupled;
        solver          GMRES;
        preconditioner  DILU;
        tolerance       (1e-08 1e-08 1e-08);
        relTol          (0 0 0);
    }

    rhoE
    {
        solver          GMRES;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0;
    }

  blockSolver
    {
      tolerance      1e-09;
    }

}
